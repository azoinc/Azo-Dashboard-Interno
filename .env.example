# ── Supabase (obrigatório) ────────────────────────────────────────────────────
SUPABASE_DB_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres

# ── Firebase Client SDK (preencha com seus dados) ────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ─── Firestore Database (opcional - padrão é "(default)") ───────────────────
NEXT_PUBLIC_FIREBASE_DATABASE_ID=(default) # ou nome customizado ex: Azo Dash Mkt

# ─── Firebase Admin SDK (somente servidor) ──────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
FIREBASE_DATABASE_ID=(default) # ou nome customizado ex: Azo Dash Mkt

# ─── WebAuthn / Passkeys (FIDO2) ────────────────────────────────────────────
RP_ID=localhost # ou seu domínio sem https (ex: azo-dashboard.vercel.app)
EXPECTED_ORIGIN=http://localhost:3000 # ou https://seu-dominio.com

# ─── Sienge API (somente servidor — NÃO use NEXT_PUBLIC) ─────────────────────
SIENGE_SUBDOMAIN=your-company
SIENGE_USERNAME=your-api-user
SIENGE_PASSWORD=your-api-password
