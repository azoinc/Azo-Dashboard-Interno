# ─── Firebase (Client SDK — prefixo NEXT_PUBLIC expõe ao browser) ────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ─── Firebase Admin SDK (somente servidor — NÃO use NEXT_PUBLIC) ──────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Cole a chave privada do JSON do service account (mantenha as \n literais)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# ─── Sienge API (somente servidor — NÃO use NEXT_PUBLIC) ─────────────────────
SIENGE_SUBDOMAIN=your-company
SIENGE_USERNAME=your-api-user
SIENGE_PASSWORD=your-api-password

# ─── Sienge feature flag (exposto ao browser para habilitar/desabilitar UI) ──
# Defina como "true" para habilitar o painel Sienge no dashboard
NEXT_PUBLIC_SIENGE_ENABLED=

# ─── Supabase PostgreSQL direto (somente servidor — NÃO use NEXT_PUBLIC) ─────
# Opção 1 — Connection string completa (recomendado)
# Encontre em: Supabase Dashboard > Settings > Database > Connection string > URI
# Use a porta 5432 (direct) ou 6543 (pgBouncer/pooler)
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Opção 2 — Variáveis separadas (use se não usar SUPABASE_DB_URL)
# SUPABASE_DB_HOST=db.[PROJECT-REF].supabase.co
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASSWORD=your-database-password
