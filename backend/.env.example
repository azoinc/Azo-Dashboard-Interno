# ── PostgreSQL direto (mesmo banco do server.ts) ──────────────────────────────
SP_HOST=aws-1-sa-east-1.pooler.supabase.com
SP_USER=postgres.[PROJECT-REF]
SP_PS=your-password
SP_PORT=6543
SP_DB=postgres

# ── Sienge ERP API (credenciais ficam APENAS no servidor) ─────────────────────
SIENGE_SUBDOMAIN=your-company
SIENGE_USERNAME=your-api-user
SIENGE_PASSWORD=your-api-password

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_DATABASE_ID=(default)

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Cache TTL (segundos) ──────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300
